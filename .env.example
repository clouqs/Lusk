# Database (required) - Railway provides this automatically when you add a PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session secret (required) - generate a random string, e.g.: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-secret

# OpenAI (required for AI features)
OPENAI_API_KEY=sk-...

# Port (optional - Railway sets this automatically)
PORT=5000
